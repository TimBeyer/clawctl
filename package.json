{
  "name": "clawctl",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "clawctl": "./bin/cli.tsx"
  },
  "scripts": {
    "dev": "bun bin/cli.tsx",
    "build": "bun build ./bin/cli.tsx --compile --outfile dist/clawctl",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:vm": "CLAWCTL_VM_TESTS=1 bun test tests/vm/"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dedent": "^1.7.2",
    "execa": "^9.0.0",
    "ink": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  }
