{
  "name": "clawctl",
  "version": "0.4.9",
  "type": "module",
  "bin": {
    "clawctl": "./bin/cli.tsx"
  },
  "scripts": {
    "dev": "bun bin/cli.tsx",
    "build": "bun build ./bin/cli.tsx --compile --outfile dist/clawctl",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:vm": "CLAWCTL_VM_TESTS=1 bun test tests/vm/",
    "build:release": "bun build ./bin/cli.tsx --compile --target=bun-darwin-arm64 --outfile dist/clawctl",
    "release": "release-it"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dedent": "^1.7.2",
    "execa": "^9.0.0",
    "ink": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "tagAnnotation": "Release v${version}",
      "requireCleanWorkingDir": false
    },
    "github": {
      "release": true,
      "draft": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    },
    "hooks": {
      "after:bump": "bun run format"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  }
}
