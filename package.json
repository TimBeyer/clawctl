{
  "name": "clawctl",
  "version": "0.17.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "clawctl": "./packages/cli/bin/cli.tsx"
  },
  "scripts": {
    "dev": "bun packages/cli/bin/cli.tsx",
    "build:claw": "bun scripts/build.ts claw",
    "build": "bun scripts/build.ts",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:vm": "CLAWCTL_VM_TESTS=1 bun test packages/host-core/tests/vm/",
    "build:release": "bun scripts/build.ts release",
    "release": "release-it",
    "docs:dev": "cd docs-site && bun run dev",
    "docs:build": "cd docs-site && bun run build",
    "docs:preview": "cd docs-site && bun run preview"
  },
  "dependencies": {
    "@clawctl/host-core": "workspace:*",
    "@clawctl/templates": "workspace:*",
    "@clawctl/types": "workspace:*",
    "commander": "^14.0.3",
    "dedent": "^1.7.2",
    "execa": "^9.0.0",
    "ink": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "tagAnnotation": "Release v${version}",
      "requireCleanWorkingDir": false
    },
    "github": {
      "release": true,
      "draft": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    },
    "hooks": {
      "after:bump": "bun run format"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/semver": "^7.7.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  }
}
