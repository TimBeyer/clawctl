---
import FadeIn from "./FadeIn.astro";
import Terminal from "./Terminal.astro";
---

<section class="relative z-10 max-w-5xl mx-auto px-6 py-20">
  <FadeIn>
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-3xl md:text-4xl text-white tracking-tight">
        Your fleet, at a glance
      </h2>
      <p class="mt-3 text-slate-400 text-lg max-w-xl mx-auto">
        Every instance is its own isolated VM. See them all with one command.
      </p>
    </div>
  </FadeIn>

  <FadeIn delay={80}>
    <Terminal title="~ — clawctl list">
      <div class="whitespace-pre text-slate-400">
        <span class="text-accent select-none">$ </span>
        <span class="text-slate-200">clawctl list</span>
      </div>
      <div class="whitespace-pre mt-3">
        <div class="text-slate-500">
          {"NAME           STATUS   PROJECT                       PROVIDER   PORT"}
        </div>
        <div class="text-slate-300">
          {"research-ai    "}<span class="text-green">Running</span>{"  ~/openclaw-vms/research-ai    anthropic  18789"}
        </div>
        <div class="text-slate-300">
          {"code-review    "}<span class="text-green">Running</span>{"  ~/openclaw-vms/code-review    openai     18790"}
        </div>
        <div class="text-slate-300">
          {"data-pipeline  "}<span class="text-red">Stopped</span>{"  ~/openclaw-vms/data-pipeline  anthropic  18791"}
        </div>
      </div>
    </Terminal>
  </FadeIn>
</section>
