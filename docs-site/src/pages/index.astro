---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import CreateDemo from "../components/CreateDemo.astro";
import Divider from "../components/Divider.astro";
import FleetDemo from "../components/FleetDemo.astro";
import Features from "../components/Features.astro";
import ConfigSection from "../components/ConfigSection.astro";
import ManagementDemo from "../components/ManagementDemo.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <div class="min-h-screen relative">
    <!-- Background layers -->
    <div class="fixed inset-0 bg-dots pointer-events-none"></div>
    <div class="fixed inset-0 bg-glow-hero pointer-events-none"></div>
    <div class="noise-overlay"></div>

    <Nav />
    <Hero />

    <CreateDemo />
    <Divider />

    <div class="bg-glow-mid">
      <FleetDemo />
      <Divider />
      <Features />
    </div>

    <Divider />
    <ConfigSection />
    <Divider />
    <ManagementDemo />
    <Divider />
    <FinalCTA />
    <Footer />
  </div>
</Base>
